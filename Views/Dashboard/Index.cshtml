@model CodeKurs.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Dein Fortschritt";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-5 text-dark"><i class="bi bi-speedometer2"></i> Dein Lern-Dashboard</h1>
            <p class="text-muted lead">Hier siehst du deinen aktuellen Fortschritt auf der Plattform.</p>
        </div>
    </div>

    <!-- Statistik-Karten -->
    <div class="row g-4 mb-4">
        @foreach (var lang in Model.LanguageStats)
        {
            var langName = lang.Key.ToUpper() == "CSHARP" ? "C#" : (lang.Key.ToUpper() == "JAVASCRIPT" ? "JavaScript" : lang.Key.ToUpper());
            var bgColor = lang.Key.ToLower() == "csharp" ? "bg-primary" : (lang.Key.ToLower() == "javascript" ? "bg-warning text-dark" : "bg-danger");
            
            <div class="col-md-4">
                <div class="card border-0 shadow-sm @bgColor h-100 p-2">
                    <div class="card-body">
                        <h6 class="card-title opacity-75">Kurs: @langName</h6>
                        <div class="d-flex justify-content-between align-items-end mt-2">
                            <div>
                                <span class="h2 fw-bold mb-0">@lang.Value.Completed/@lang.Value.Total</span>
                                <p class="small mb-0 opacity-75">Aufgaben gelöst</p>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold">@Math.Round(lang.Value.Percentage)%</span>
                            </div>
                        </div>
                        <div class="progress mt-2" style="height: 6px; background-color: rgba(255,255,255,0.2);">
                            <div class="progress-bar bg-white" role="progressbar" style="width: @lang.Value.Percentage%"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Gesamt-Fortschritt -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm bg-dark text-white p-2">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div class="flex-grow-1 me-4">
                        <h6 class="opacity-75 mb-1">Gesamt-Lernfortschritt</h6>
                        <div class="progress" style="height: 12px; background-color: rgba(255,255,255,0.1);">
                            <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" role="progressbar" style="width: @Model.ProgressPercentage%"></div>
                        </div>
                    </div>
                    <div class="text-center">
                        <span class="display-6 fw-bold">@Math.Round(Model.ProgressPercentage)%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Aufgaben-Details -->
    <div class="row">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Detaillierte Übersicht</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Aufgabe</th>
                                <th>Typ</th>
                                <th>Status</th>
                                <th>Letzte Änderung</th>
                                <th class="text-end pe-4">Aktion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.TaskDetails)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@task.Title</div>
                                    </td>
                                    <td>
                                        <span class="badge @(task.Type == TaskType.Programming ? "bg-info text-dark" : "bg-warning text-dark")">
                                            @(task.Type == TaskType.Programming ? "Programmierung" : "Quiz")
                                        </span>
                                    </td>
                                    <td>
                                        @if (task.IsCompleted)
                                        {
                                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Abgeschlossen</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="bi bi-circle"></i> Offen</span>
                                        }
                                    </td>
                                    <td>
                                        @(task.LastUpdated?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Home" asp-action="Index" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            @(task.IsCompleted ? "Wiederholen" : "Starten")
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
