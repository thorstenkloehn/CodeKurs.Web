@model List<string>
@{
    ViewData["Title"] = "Kurs auswählen";
}

<div class="container mt-5">
    <div class="row mb-5">
        <div class="col-md-12 text-center">
            <h1 class="display-4 fw-bold">Wähle deinen Kurs</h1>
            <p class="lead text-muted">Jede Programmiersprache ist ein eigenständiger Lernpfad.</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        @foreach (var lang in Model)
        {
            var displayLang = lang.ToUpper() == "CSHARP" ? "C#" : (lang.ToUpper() == "JAVASCRIPT" ? "JavaScript" : lang.Substring(0, 1).ToUpper() + lang.Substring(1));
            var icon = lang.ToLower() switch {
                "csharp" => "bi-hash",
                "java" => "bi-cup-hot",
                "javascript" => "bi-braces",
                "go" => "bi-terminal",
                "php" => "bi-filetype-php",
                "python" => "bi-filetype-py",
                "c" => "bi-filetype-c",
                "rust" => "bi-gear-fill",
                "cpp" => "bi-filetype-cpp",
                "geminicli" => "bi-magic",
                _ => "bi-code-square"
            };
            var colorClass = lang.ToLower() switch {
                "csharp" => "btn-primary",
                "java" => "btn-danger",
                "javascript" => "btn-warning",
                "go" => "btn-info",
                "php" => "btn-dark",
                "python" => "btn-success",
                "c" => "btn-secondary",
                "rust" => "btn-outline-danger",
                "cpp" => "btn-primary",
                "geminicli" => "bi-info",
                _ => "btn-dark"
            };

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi @icon" style="font-size: 4rem;"></i>
                        </div>
                        <h2 class="card-title fw-bold">@displayLang</h2>
                        <p class="card-text text-muted mb-4">Lerne @displayLang von den Grundlagen bis zu fortgeschrittenen Themen.</p>
                        <a asp-action="Index" asp-route-language="@lang" class="btn @colorClass btn-lg px-4 rounded-pill">Kurs starten</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .transition {
        transition: all 0.3s ease-in-out;
    }
</style>
