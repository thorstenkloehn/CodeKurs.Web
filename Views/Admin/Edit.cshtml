@model CodeKurs.Web.Models.ProgrammingTask
@using CodeKurs.Web.Models

@{
    ViewData["Title"] = "Aufgabe bearbeiten";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">Aufgabe bearbeiten</h2>
                    <a asp-action="Index" class="btn btn-outline-light btn-sm">Zurück zur Liste</a>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <!-- Linke Spalte: Stammdaten -->
                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">Allgemein</h5>
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label">Titel</label>
                                    <input asp-for="Title" class="form-control" />
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="LessonId" class="form-label">Lektion</label>
                                    <select asp-for="LessonId" class="form-select" asp-items="@(new SelectList(ViewBag.Lessons, "Id", "Title"))">
                                        <option value="">-- Keine Lektion --</option>
                                    </select>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="Type" class="form-label">Typ</label>
                                        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<TaskType>()"></select>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Language" class="form-label">Sprache</label>
                                        <select asp-for="Language" class="form-select">
                                            <option value="csharp">C#</option>
                                            <option value="java">Java</option>
                                            <option value="javascript">JavaScript</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Order" class="form-label">Reihenfolge (Sortierung)</label>
                                    <input asp-for="Order" class="form-control" type="number" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="PlaceholderDependency" class="form-label">Abhängig von Voraufgabe (ID)</label>
                                    <input asp-for="PlaceholderDependency" class="form-control" placeholder="z.B. 4" />
                                </div>
                            </div>

                            <!-- Rechte Spalte: Validierung -->
                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">Validierung & Prüfung</h5>
                                <div class="mb-3">
                                    <label asp-for="ExpectedOutput" class="form-label">Erwarteter Output (für Output-Validierung)</label>
                                    <textarea asp-for="ExpectedOutput" class="form-control" rows="2"></textarea>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="RequiredKeywords" class="form-label">Pflicht-Schlüsselwörter (kommagetrennt)</label>
                                    <input asp-for="RequiredKeywords" class="form-control" placeholder="class,public,void" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="CorrectAnswer" class="form-label">Richtige Antwort (für Quiz)</label>
                                    <input asp-for="CorrectAnswer" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="ChoicesJson" class="form-label">Quiz Optionen (JSON-Array)</label>
                                    <input asp-for="ChoicesJson" class="form-control" placeholder='["Option 1", "Option 2"]' />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Beschreibung (HTML/Markdown möglich)</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="InitialCode" class="form-label">Start-Code für Student</label>
                                    <textarea asp-for="InitialCode" class="form-control font-monospace" rows="8"></textarea>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TestCode" class="form-label">Versteckter Test-Code (für Edu-Tasks)</label>
                                    <textarea asp-for="TestCode" class="form-control font-monospace" rows="8"></textarea>
                                    <small class="text-muted">Muss SUCCESS_ALL_TESTS_PASSED ausgeben.</small>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary px-5">Speichern</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
