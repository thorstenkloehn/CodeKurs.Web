{
  "name": "codekurs-vscode",
  "displayName": "CodeKurs: Interaktive Programmierkurse",
  "description": "Lerne Programmieren direkt in VS Code mit Theorie und interaktiven Übungen.",
  "version": "1.0.0",
  "publisher": "thorsten",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codekurs-explorer",
          "title": "CodeKurs",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "codekurs-explorer": [
        {
          "id": "codekurs-lessons",
          "name": "Kurs-Übersicht"
        }
      ]
    },
    "commands": [
      {
        "command": "codekurs.openLesson",
        "title": "Lektion öffnen"
      },
      {
        "command": "codekurs.checkCode",
        "title": "Code prüfen",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "editorTextFocus",
          "command": "codekurs.checkCode",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "marked": "^5.1.0"
  }
}
